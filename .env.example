COUNTRY=tr
PORT=3000
NODE_ENV=development

# Database (DB_MODE: single | cluster)
DB_MODE=single
DB_HOST=localhost
DB_PORT=5432
DB_USER=otc
DB_PASS=password
DB_NAME=otc_db

# Redis (REDIS_MODE: standalone | sentinel)
REDIS_MODE=standalone
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis Sentinel (only when REDIS_MODE=sentinel)
REDIS_SENTINELS=host1:26379,host2:26379,host3:26379
REDIS_SENTINEL_MASTER=mymaster
REDIS_SENTINEL_PASSWORD=
