model Order {
  id        String @id @default(uuid()) @db.Uuid
  accountId String @map("account_id") @db.Uuid

  sourceCurrencyId String @map("source_currency_id") @db.Uuid
  targetCurrencyId String @map("target_currency_id") @db.Uuid

  sourceAmount Decimal @map("source_amount") @db.Decimal(36, 18)
  targetAmount Decimal @map("target_amount") @db.Decimal(36, 18)

  rate Decimal @db.Decimal(36, 18)

  status    OrderStatus    @default(INITIATED)
  subStatus OrderSubStatus @default(AWAITING_ADMIN_APPROVAL) @map("sub_status")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  details Json @db.JsonB

  transactions   Transaction[]
  actionTrackers OrderActionTracker[]

  @@map("orders")
}
